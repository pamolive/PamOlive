{
  admin off
  auto_https off
}

:8081 {
  encode zstd gzip

  handle /launch/* {
    reverse_proxy rdp-broker:8002
  }

  handle /guacamole/* {
    reverse_proxy guacamole:8080
  }

  handle {
    redir /guacamole/ 302
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
    X-Frame-Options DENY
    Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"
  }
}
