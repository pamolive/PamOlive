FROM python:3.14-alpine@sha256:26730869004e2b9c4b9ad09cab8625e81d256d1ce97e72df5520e806b1709f92

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    DJANGO_SETTINGS_MODULE=config.settings.test

RUN addgroup -S pamolive && adduser -S -G pamolive -h /home/pamolive pamolive
WORKDIR /app

COPY pyproject.toml README.md ./
COPY pamolive ./pamolive
COPY config ./config
COPY manage.py ./
COPY templates ./templates
COPY static ./static
COPY tests ./tests

RUN pip install --upgrade pip && pip install ".[dev]" && chown -R pamolive:pamolive /app

USER pamolive
CMD ["pytest", "--cov=pamolive", "--cov-fail-under=90", "-q"]
