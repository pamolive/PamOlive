DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
CBPAM_HTTP_BIND=127.0.0.1
CBPAM_HTTP_PORT=8000
CBPAM_RDP_ENABLED=true
CBPAM_RDP_PUBLIC_ORIGIN=http://localhost:8081
CBPAM_RDP_HTTP_BIND=127.0.0.1
CBPAM_RDP_HTTP_PORT=8081
POSTGRES_DB=pamolive
POSTGRES_USER=pamolive
POSTGRES_PASSWORD=generate-a-long-random-database-password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0
CBPAM_VAULT_KEY=
CBPAM_VAULT_KEYS={}
CBPAM_VAULT_ACTIVE_KEY_ID=legacy
CBPAM_AUDIT_SIGNING_KEY=generate-a-distinct-random-value-of-at-least-32-characters
CBPAM_GATEWAY_SHARED_KEY=generate-a-distinct-random-value-of-at-least-32-characters
CBPAM_RECORDING_KEY=generate-a-distinct-random-value-of-at-least-32-characters
CBPAM_OPERATIONS_TOKEN=generate-a-distinct-random-value-of-at-least-32-characters
CBPAM_GUACAMOLE_JSON_KEY=generate-a-distinct-32-character-hex-value
CBPAM_ROTATION_BACKENDS={}
