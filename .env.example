# Do not copy this file as-is. Run `make init` or `sh install.sh`.
# Secret values are intentionally blank and must never be committed.

# Django profile, signing secret, accepted hosts, and trusted HTTPS origins.
DJANGO_SETTINGS_MODULE=
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=
PAMOLIVE_PUBLIC_URL=
PAMOLIVE_MFA_STEP_UP_MAX_AGE_SECONDS=

# PostgreSQL database identity and connection URL.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis authentication secret and authenticated connection URL.
REDIS_PASSWORD=
REDIS_URL=
REDIS_TLS_CA_PATH=

# Internal keyring endpoint, timeout, and independent Bearer authentication token.
PAMOLIVE_KEYRING_URL=
PAMOLIVE_KEYRING_TIMEOUT_SECONDS=
PAMOLIVE_KEYRING_TOKEN=
PAMOLIVE_KEYRING_RATE_LIMIT_PER_MINUTE=
PAMOLIVE_KEYRING_DECRYPT_LIMIT_PER_MINUTE=

# Independent broker, recording, operations, and Guacamole secrets.
PAMOLIVE_GATEWAY_SHARED_KEY=
PAMOLIVE_GATEWAY_ACCEPT_LEGACY_SIGNATURES=
PAMOLIVE_RECORDING_KEY=
PAMOLIVE_OPERATIONS_TOKEN=
PAMOLIVE_GUACAMOLE_JSON_KEY=

# Local listener settings and the dedicated public RDP origin.
PAMOLIVE_HTTP_BIND=
PAMOLIVE_HTTP_PORT=
PAMOLIVE_RDP_ENABLED=
PAMOLIVE_RDP_PUBLIC_ORIGIN=
PAMOLIVE_RDP_HTTP_BIND=
PAMOLIVE_RDP_HTTP_PORT=

# Non-overlapping Docker subnets and optional rotation connector registry.
PAMOLIVE_FRONTEND_SUBNET=
PAMOLIVE_INTERNAL_SUBNET=
PAMOLIVE_TARGETS_SUBNET=
PAMOLIVE_ROTATION_BACKENDS=
